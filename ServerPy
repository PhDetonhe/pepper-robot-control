from flask import Flask, request, jsonify, render_template_string

app = Flask(__name__)

valor_pot = 0

# potenciômetro virtual temporario pra teste
HTML = """
<!DOCTYPE html>
<html>
<head>
    <title>Controle do Robô</title>
</head>
<body>
    <h1>Controle do Robô</h1>
    
    <input type="range" min="0" max="4095" value="0" id="slider" oninput="enviarValor(this.value)">
    
    <p>Valor: <span id="valor">0</span></p>

    <script>
        function enviarValor(valor) {
            document.getElementById("valor").innerText = valor;

            fetch('/set?valor=' + valor)
        }
    </script>
</body>
</html>
"""

@app.route('/')
def home():
    return render_template_string(HTML)

# Recebe valor do navegador
@app.route('/set')
def set_valor():
    global valor_pot
    valor_pot = int(request.args.get("valor", 0))
    return "OK"

# Envia valor pro robô
@app.route('/pot')
def get_valor():
    return jsonify({"valor": valor_pot})

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)
