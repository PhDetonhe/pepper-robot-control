import urllib2
import json

class MyClass(GeneratedClass):
    def __init__(self):
        GeneratedClass.__init__(self)

    def onLoad(self):
        self.motion = ALProxy("ALMotion")
        self.motion.wakeUp()

    def onUnload(self):
        self.motion.rest()

    def onInput_onStart(self):
        try:
            response = urllib2.urlopen("http://192.168.1.8:5000/pot")
            data = json.loads(response.read())

            valor = data["valor"]

            # Converter valor (0–4095) para distância (0–1 metro)
            distancia = valor / 4095.0

            self.motion.moveTo(distancia, 0, 0)

        except Exception as e:
            self.logger.error(str(e))

        self.onStopped()
